# grace-board configuration.
# Copy to `.env` (auto-loaded on start) or export these in your shell.
# An already-exported environment variable always wins over the .env value.

# Port the board listens on. Bound to 127.0.0.1 (local only), never exposed.
GRACE_BOARD_PORT=4317

# Root directory where your projects live. A dispatched run must resolve to a
# path INSIDE this root (a safety guard) — set it to your real projects folder.
GRACE_PROJECTS_ROOT=/Users/youruser/Projects

# Path to the Claude CLI binary the server spawns for headless runs.
GRACE_CLAUDE_BIN=/Users/youruser/.local/bin/claude

# Optional: extra PATH entries (":"-separated) prepended for spawned runs, in case
# claude/node aren't on the server's PATH. Defaults are derived automatically.
# GRACE_BIN_PATH=/Users/youruser/.local/bin:/opt/homebrew/bin

# Optional: set to 0 to disable auto-launching runs (compose/preview the board only).
# GRACE_AUTORUN=1

# Optional: minutes a run may sit in one station before the self-healing watchdog
# intervenes (auto-relaunch once, then block). Default 120.
# GRACE_STALL_MIN=120
